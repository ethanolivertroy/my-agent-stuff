{
  "name": "my-agent-stuff",
  "version": "0.0.1",
  "description": "Public agent skills for Pi, Codex, and compatible Agent Skills runtimes.",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "agent-skills",
    "pi",
    "codex",
    "security",
    "grc",
    "pi-extension",
    "subagents",
    "autoresearch",
    "tts",
    "web-search",
    "pi-skill",
    "pi-prompt"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./commands"
    ]
  },
  "scripts": {
    "secrets:scan": "scripts/secret-scan.sh --working-tree",
    "secrets:scan-history": "scripts/secret-scan.sh --all",
    "secrets:install-hooks": "git config core.hooksPath .githooks",
    "linear:smoke": "node scripts/linear-mcp-smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "0.2.15",
    "@opentui/react": "0.2.15",
    "@sinclair/typebox": "^0.34.41",
    "jiti": "^2.7.0",
    "js-yaml": "^4.1.0",
    "react": "^19.2.0",
    "typebox": "^1.1.33"
  }
}
